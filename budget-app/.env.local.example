# Supabase (webhook 핸들러용 - service role key는 절대 공개 금지)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Note: SUPABASE_ANON_KEY is intentionally hardcoded in index.html (safe to expose publicly)
# Only the SERVICE_ROLE_KEY must remain secret
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Polar.sh
POLAR_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
